{
  "expo": {
    "name": "TapIn",
    "slug": "tapin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/favicon.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "scheme": "attendance-app",
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withNinjaLongPaths",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5B6EF5",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Office Attendance to record your location when you check in or out for HR audit purposes."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendance.app"
    },
    "android": {
      "package": "com.attendance.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b1a405c-b7c6-4722-b4b4-76af43673c40"
      }
    }
  }
}