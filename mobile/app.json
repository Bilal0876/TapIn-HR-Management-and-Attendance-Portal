{
  "expo": {
    "name": "TapIn",
    "slug": "tapin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "attendance-app",
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withNinjaLongPaths",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Office Attendance to record your location when you check in or out for HR audit purposes."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendance.app"
    },
    "android": {
      "package": "com.attendance.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2f01c36d-2396-4487-b748-6860fcb9d344"
      }
    }
  }
}
