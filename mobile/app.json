{
  "expo": {
    "name": "Office Attendance",
    "slug": "office-attendance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "attendance-app",
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withNinjaLongPaths",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Office Attendance to record your location when you check in or out for HR audit purposes."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attendance.app"
    },
    "android": {
      "package": "com.attendance.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
